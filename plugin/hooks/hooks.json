{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-update.sh\"",
            "timeout": 8000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*__claim_issue",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-locked-version-blocker.js\"",
            "timeout": 20000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-version-summary.js\"",
            "timeout": 8000
          }
        ]
      }
    ]
  }
}
